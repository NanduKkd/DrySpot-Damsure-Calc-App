#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REQUIREMENTS_FILE="$SCRIPT_DIR/docs/current/requirements.md"
export GEMINI_SYSTEM_MD="$SCRIPT_DIR/.gemini/system-ba.md"

gemini "$@"

if [ "${GEMINI_AUTO_CHAIN:-1}" = "1" ] && [ -f "$REQUIREMENTS_FILE" ] && grep -q 'READY_FOR_IMPLEMENTATION' "$REQUIREMENTS_FILE"; then
	"$SCRIPT_DIR/scripts/run-post-ba-flow.sh"
fi
